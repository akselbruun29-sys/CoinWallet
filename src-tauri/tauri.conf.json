{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CoinWallet",
  "version": "0.1.0",
  "identifier": "com.coinwallet.desktop",
  "build": {
    "frontendDist": "../admin/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix admin",
    "beforeBuildCommand": "npm run build:desktop --prefix admin"
  },
  "app": {
    "windows": [
      {
        "title": "CoinWallet",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8002 http://localhost:8002 https://blockstream.info https://*.xmrchain.net; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
