{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CoinWallet",
  "version": "0.1.0",
  "identifier": "com.coinwallet.desktop",
  "build": {
    "frontendDist": "../admin/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix admin",
    "beforeBuildCommand": "npm run build:desktop --prefix admin"
  },
  "app": {
    "windows": [
      {
        "title": "CoinWallet",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/coinwallet-api"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/tor/*"
    ]
  }
}
