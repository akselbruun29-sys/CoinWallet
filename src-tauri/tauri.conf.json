{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CoinWallet",
  "version": "0.1.0",
  "identifier": "com.coinwallet.desktop",
  "build": {
    "frontendDist": "../admin/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix admin",
    "beforeBuildCommand": "npm run build:desktop --prefix admin"
  },
  "app": {
    "windows": [
      {
        "title": "CoinWallet",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset: http://asset.localhost https://asset.localhost tauri: https://tauri.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost https://ipc.localhost http://127.0.0.1:8002 http://localhost:8002 ws://127.0.0.1:8002 ws://localhost:8002 https://blockstream.info https://*.xmrchain.net https://*.workers.dev https://coinwallet.pages.dev",
        "font-src": "'self' data:",
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost blob: data:",
        "style-src": "'unsafe-inline' 'self'",
        "script-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/coinwallet-api"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
