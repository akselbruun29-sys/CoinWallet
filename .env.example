# ============================================
# COINWALLET — LOCAL WALLET API
# ============================================

# Bitcoin network: testnet | signet | regtest | mainnet
BITCOIN_NETWORK=testnet

# Bitcoin backend — Esplora (testnet default)
BITCOIN_BACKEND_URI=https://blockstream.info/testnet/api/

# Backend type: esplora | core (Core RPC hybrid uses Esplora for address indexes)
BITCOIN_BACKEND_TYPE=esplora
BITCOIN_RPC_URI=http://127.0.0.1:18332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=

# Encrypt wallet mnemonics — server pepper (required; not sufficient alone to decrypt user wallets)
WALLET_ENCRYPTION_KEY=change-this-to-a-long-random-secret-key

# Wallet unlock session TTL in seconds (default 900 = 15 min); admin can override via Settings
WALLET_UNLOCK_TTL=900
# Extend wallet unlock idle timer on GET requests (default true; set false for stricter auto-lock)
WALLET_TOUCH_ON_READ=true

# Auth session idle timeout in seconds (default 3600 = 1 hour); max age remains 7 days
SESSION_IDLE_SECONDS=3600

# Set true behind HTTPS reverse proxy
SECURE_COOKIES=false

# Exit on startup if SESSION_SECRET / WALLET_ENCRYPTION_KEY are weak (required for desktop release)
STRICT_SECRETS=false

# Set true for production/release builds (requires STRICT_SECRETS=true)
COINWALLET_PRODUCTION=false

# Comma-separated browser origins allowed for CORS and CSRF Origin checks
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Bind API to localhost only (default). Set ALLOW_REMOTE_API_HOST=true to disable Host check.
# LOCALHOST_ONLY=true

# Caddy site address (docker compose)
SITE_ADDRESS=localhost

# Per-wallet engine data directory (reserved for future use)
BDK_DATA_DIR=./data/bdk

# Optional Tor proxy for backend connections (desktop app sets these automatically)
TOR_ENABLED=false
HTTP_PROXY=
HTTPS_PROXY=
TOR_SOCKS_PROXY=socks5h://127.0.0.1:9050
# Set by Tauri when bundled Tor is running — do not set manually unless debugging
# COINWALLET_TOR_MANAGED=true

# Optional CoinJoin coordinator URI — Phase 3
COORDINATOR_URI=

# Allow mainnet wallet create/import (default: false)
ALLOW_MAINNET=false

# Monero wallet-rpc JSON-RPC URI (stagenet default)
# XMR_WALLET_RPC_URI=http://127.0.0.1:38088/json_rpc

# ============================================
# RATE LIMITING
# ============================================
# memory (default) or file for multi-process sidecars
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_FILE=./data/rate_limits.json

# ============================================
# SWAP (BTC ↔ XMR)
# ============================================
# Comma-separated provider IDs: rate_table, haveno
# SWAP_PROVIDER_ALLOWLIST=rate_table,haveno
SWAP_RATE_TABLE_ENABLED=
SWAP_RATE_BTC_TO_XMR=0.15
SWAP_PROVIDER_FEE_BPS=30

# ============================================
# AUTH & USERS
# ============================================
# Generate hash: python scripts/hash_password.py yourpassword
# Wrap hash in double quotes in .env (bcrypt hashes contain $ characters)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
# Dev only — use ADMIN_PASSWORD_HASH in production instead:
# ADMIN_PASSWORD=changeme

SESSION_SECRET=change-this-to-a-random-string

# Allow public registration (default: false — admin creates users)
OPEN_REGISTRATION=false

# Auto-approve new registrations as "user" role (false = "pending")
AUTO_APPROVE_USERS=true

# Database file
WALLET_DB=wallet.db

# ============================================
# REMOTE SERVICES (internet-only — Wasabi-style local wallet)
# ============================================
# Local desktop app: wallet/signing/sync stay on 127.0.0.1. Only leaderboard + optional AI use these URLs.
# COINWALLET_REMOTE_SERVICES_URL=https://api.coinwallet.example.com
# LEADERBOARD_CLOUD_MODE=true   # set on cloud deploy only (api/cloud_app.py)
# VITE_REMOTE_SERVICES_URL=       # admin + site leaderboard reads (build-time)
# VITE_ADVISOR_AI_URL=            # optional cloud AI hints (no mnemonics sent)

# Optional: seal wallet.db as wallet.db.cwenc on API shutdown (desktop production)
# See .env.production.desktop.example for a full production template
# WALLET_DB_KEY=
