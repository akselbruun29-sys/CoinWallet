# CoinWallet desktop production sidecar — copy beside the installed app data dir or set before first launch.
# Generate secrets: python -c "import secrets; print(secrets.token_urlsafe(32))"

STRICT_SECRETS=true
COINWALLET_PRODUCTION=true

# Required — unique per installation / operator
WALLET_ENCRYPTION_KEY=
SESSION_SECRET=
WALLET_DB_KEY=

# Strong admin login (bcrypt hash in quotes — see scripts/hash_password.py)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Defaults safe for first-run
BITCOIN_NETWORK=testnet
OPEN_REGISTRATION=false
AUTO_APPROVE_USERS=true
ALLOW_MAINNET=false

# Local API only (Tauri sidecar sets host/port; do not expose remotely)
LOCALHOST_ONLY=true

# Optional swap provider restriction (comma-separated)
# SWAP_PROVIDER_ALLOWLIST=rate_table,haveno

WALLET_DB=wallet.db
WALLET_UNLOCK_TTL=900
SESSION_IDLE_SECONDS=3600

# Optional — sync opt-in leaderboard to public cloud (display name + balance only)
# COINWALLET_REMOTE_SERVICES_URL=https://api.coinwallet.example.com
